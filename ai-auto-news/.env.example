# --- URLs ---
# Used for absolute links in RSS/sitemap/robots. If unset, it is derived from the request host.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- AI provider ---
# `mock` works with zero external configuration and is the recommended default for localhost.
# Set `AI_PROVIDER=gemini` and `GEMINI_API_KEY` to enable live content generation.
AI_PROVIDER=mock
GEMINI_API_KEY=

# --- Admin auth (local) ---
# Use long, random values in production.
JWT_SECRET=dev-secret-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Background services ---
# These run only at runtime (next dev / next start), never during build/tests.
SCHEDULER_ENABLED=true
TASK_QUEUE_ENABLED=true

# Scheduler cadence (milliseconds). Default: 2 hours (7200000).
SCHEDULER_INTERVAL_MS=7200000

# Task queue poll interval (milliseconds). Default: 10000.
TASK_QUEUE_INTERVAL_MS=10000

# --- Experimental APIs ---
# /api/v2/* and /api/v3/* are experimental and require admin auth for mutations by default.
# Set true ONLY for local development/testing.
ALLOW_INSECURE_EXPERIMENTAL_APIS=false

# --- Logging ---
LOG_LEVEL=info
